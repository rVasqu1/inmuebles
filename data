                                    <Text text="{tipologiaCeco>num}"/>
                                </t:template>
                        </t:Column>

                        <t:Column autoResizable="true"
                                  width="6rem">
                            <Label text="{i18n>ceco}" required="true" />
                                <t:template>
                                    <Input value="{tipologiaCeco>ceco}" textAlign="End"/>
                                </t:template>
                        </t:Column>

                        <t:Column width="7rem"
                                  autoResizable="true">
                            <Label text="{i18n>dedicacion}" required="true"/>
                                <t:template>
                                   <Input value="{tipologiaCeco>dedicacion}" textAlign="End"/>
                                </t:template>
                        </t:Column>

                        <t:Column autoResizable="true"
                                  width="15rem">
                                  <Label text="{i18n>tipologia}" required="true"/>
                                   <t:template>
                                   
                                  <Select width="100%"
					forceSelection="false"
					selectedKey="{tipologiaCeco>tipologia}"
						items="{tipologiaCeco>/catalog/models}">
					<core:Item key="{tipologiaCeco>orden}" text="{tipologiaCeco>descripcion}" />
				</Select>
                  </t:template>
