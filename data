 <IconTabFilter text="{i18n>ceco}"> 
                    <t:Table rows="{tipologiaCeco>/catalogCeco}"> 
                    <t:extension>
                    <OverflowToolbar>
                    <ToolbarSpacer/>
                        <Button press= "dowloadExcelCeco"
                                icon="sap-icon://download"/>
                        <unified:FileUploader id="UploadCeco" 
                                              buttonOnly="true" 
                                              icon="sap-icon://upload" 
                                              change="fileUploadCeco" 
                                              buttonText=" "
                                              fileType="xlsx" 
                                              sameFilenameAllowed="true" />		
						<Button icon="sap-icon://add"
							    press="onAddRowCeco"/>
                        <Button icon="sap-icon://copy"
							    press="onCopyRowCeco"/>
						<Button icon="sap-icon://delete"
							    press="onDeleteRowCeco"/>
                    </OverflowToolbar>
                    </t:extension>
                    <t:columns>

                        <t:Column autoResizable="true"
						           width="4rem">
                            <Label text="" />
                                <t:template>
                                    <Text text="{tipologiaCeco>num}"/>
                                </t:template>
                        </t:Column>

                        <t:Column autoResizable="true"
                                  width="6rem">
                            <Label text="{i18n>ceco}" required="true" />
                                <t:template>
                                    <Input value="{tipologiaCeco>ceco}" textAlign="End"/>
                                </t:template>
                        </t:Column>

                        <t:Column width="7rem"
                                  autoResizable="true">
                            <Label text="{i18n>dedicacion}" required="true"/>
                                <t:template>
                                   <Input value="{tipologiaCeco>dedicacion}" textAlign="End"/>
                                </t:template>
                        </t:Column>

                        <t:Column autoResizable="true"
                                  width="15rem">
                                  <Label text="{i18n>tipologia}" required="true"/>
                                   <t:template>
                                  <Select width="100%"
					forceSelection="false"
					selectedKey="{tipologiaCeco/catalog/models>descripcion}"
						items="{
							path: 'tipologiaCeco>/catalog/models}'
						}">
					<core:Item key="tipologiaCeco>descripcion" text="{tipologiaCeco>descripcion}" />
				</Select>
                  </t:template>
                        </t:Column>
