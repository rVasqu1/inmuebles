oFileUploadTipoeco: function (oEvent) {
    var oFile = oEvent.getParameter("files")[0];
    if (!oFile) return;

    var reader = new FileReader();
    reader.onload = function (e) {
        var data = new Uint8Array(e.target.result);
        var workbook = XLSX.read(data, { type: "array" });
        var sheet = workbook.Sheets[workbook.SheetNames[0]];
        var rows = XLSX.utils.sheet_to_json(sheet, { header: 1 }).slice(1);

        var oModel = this.getView().getModel("mapfresa");
        var tipoCeco = oModel.getProperty("/tipoCeco");

        for (var i = 0; i < rows.length; i++) {
            var row = rows[i];

            // Salta righe vuote
            if (!row || row.length === 0) continue;

            // ✅ Le colonne del Excel in ordine (come appaiono nella tabella scaricata):
            // [0]=Orden, [1]=Description, [2]=DescriptionEng, [3]=ExecutionDate, [4]=ExecutionHour, [5]=Userid
            var sOrden          = row[0] ? row[0].toString() : "";
            var sDescription    = row[1] ? row[1].toString() : "";
            var sDescriptionEng = row[2] ? row[2].toString() : "";

            // ✅ Cerca se esiste già una riga con stesso Orden nel modello
            var oExisting = tipoCeco.find(function (t) {
                return t.Orden === sOrden;
            });

            if (oExisting) {
                // ✅ Aggiorna la riga esistente
                oExisting.Orden          = sOrden;
                oExisting.Description    = sDescription;
                oExisting.DescriptionEng = sDescriptionEng;
            } else {
                // ✅ Crea nuova entry OData
                var oContextNat = this.getView().getModel().createEntry("/ZCMSD_FACT_FEES", {
                    properties: {
                        Zsociedad: '0004'
                    }
                });

                var item = {
                    _pathSmarfield:  oContextNat.getPath(),
                    Orden:           sOrden,
                    Description:     sDescription,
                    DescriptionEng:  sDescriptionEng
                };

                tipoCeco.push(item);
                item._numerico = tipoCeco.length;
            }
        }

        oModel.setProperty("/tipoCeco", tipoCeco);
        oModel.refresh(true);
        sap.m.MessageToast.show("Excel cargado correctamente");

    }.bind(this);

    reader.readAsArrayBuffer(oFile);
},
