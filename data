this.getView().getModel().read("/ZCMSD_FACT_FEES", {
                    success: function (odata) {
                        for (var i in odata.results) {
                            var oContextCeco = this.getView().getModel().createEntry("/ZCMSD_FACT_FEES", {
                                properties: {
                                    Zsociedad: '0004',
                                    SaknrLow: odata.results[i].SaknrLow,
                                    SaknrHigh: odata.results[i].SaknrHigh
                                }
                            })
                            odata.results[i]._pathSmarfield = oContextCeco.getPath();
                            odata.results[i]._numerico = (parseInt(i) + 1);
                        }
                        this.getView().getModel("mapfresa").setProperty("/naturaleza", odata.results);
                    }.bind(this)
                })
