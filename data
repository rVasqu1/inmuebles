if(ms!=null){
    var totalSeconds = Math.floor(ms / 1000);
    var h = Math.floor(totalSeconds / 3600);
    var m = Math.floor((totalSeconds % 3600) / 60);
    var s = totalSeconds % 60;

    obj.ExecutionHour =
        h.toString().padStart(2,"0") + ":" +
        m.toString().padStart(2,"0") + ":" +
        s.toString().padStart(2,"0");
}
