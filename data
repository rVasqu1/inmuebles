oFileUpload: function (oEvent) {

    var oFile = oEvent.getParameter("files")[0];
    if (!oFile) return;

    var reader = new FileReader();

    reader.onload = function (e) {

        var data = new Uint8Array(e.target.result);
        var workbook = XLSX.read(data, { type: "array" });

        var sheet = workbook.Sheets[workbook.SheetNames[0]];

        // leggere excel come array
        var rows = XLSX.utils.sheet_to_json(sheet, { header: 1 });

        // togliere header
        rows.shift();

        var aData = rows.map(function (r, i) {

            return {
                _numerico: r[0],
                ClassId: r[1],
                SaknrLow: r[2],
                SaknrHigh: r[3],
                DateLow: r[4],
                DateHigh: r[5],
                ExecutionDate: r[6],
                ExecutionHour: r[7],
                Userid: r[8]
            };

        });

        var oModel = this.getView().getModel("mapfresa");

        oModel.setProperty("/naturaleza", aData);
        oModel.refresh(true);

    }.bind(this);

    reader.readAsArrayBuffer(oFile);
}
