oFileUpload: function (oEvent) {

    var oFile = oEvent.getParameter("files")[0];
    if (!oFile) return;

    var reader = new FileReader();

    reader.onload = function (e) {

        try {

            var data = new Uint8Array(e.target.result);
            var workbook = XLSX.read(data, { type: "array" });
            var sheet = workbook.Sheets[workbook.SheetNames[0]];

            var aExcel = XLSX.utils.sheet_to_json(sheet, { header: 1 });

            if (!aExcel.length) {
                sap.m.MessageToast.show("El Excel está vacío");
                return;
            }

            var aHeaders = aExcel[0];
            var aRows = aExcel.slice(1);

            var oTable = this.byId("tableNaturaleza");
            var aColumns = oTable.getColumns();

            // leer columnas de la tabla dinámicamente
            var aColumnInfo = aColumns.map(function (oCol) {

                var label = oCol.getLabel()?.getText()?.trim() || "";

                var template = oCol.getTemplate();
                var property = "";

                if (template) {

                    var binding =
                        template.getBindingInfo("value") ||
                        template.getBindingInfo("text") ||
                        template.getBindingInfo("selectedKey");

                    if (binding && binding.parts && binding.parts.length) {
                        property = binding.parts[0].path;
                    }
                }

                return {
                    label: label.toLowerCase(),
                    property: property
                };

            });

            // validar columnas
            var columnMap = {};
            var missingColumns = [];

            aHeaders.forEach(function (excelHeader, i) {

                if (!excelHeader) return;

                var header = excelHeader.toString().trim().toLowerCase();

                var match = aColumnInfo.find(function (col) {
                    return col.label === header;
                });

                if (match) {
                    columnMap[i] = match.property;
                } else {
                    missingColumns.push(excelHeader);
                }

            });

            if (Object.keys(columnMap).length === 0) {
                sap.m.MessageBox.error("Las columnas del Excel no coinciden con la tabla");
                return;
            }

            var aData = [];
            var errorRows = [];

            aRows.forEach(function (row, index) {

                // saltar filas completamente vacías
                if (!row || row.every(v => v === undefined || v === "")) {
                    return;
                }

                var obj = {
                    _numerico: aData.length + 1
                };

                Object.keys(columnMap).forEach(function (excelIndex) {

                    var property = columnMap[excelIndex];
                    var value = row[excelIndex];

                    if (value === undefined) return;

                    try {

                        // FECHA
                        if (value instanceof Date) {
                            obj[property] = value;
                        }

                        // HORA
                        else if (typeof value === "string" && value.match(/^\d{2}:\d{2}:\d{2}$/)) {

                            var parts = value.split(":");

                            var ms =
                                (parseInt(parts[0]) * 3600 +
                                parseInt(parts[1]) * 60 +
                                parseInt(parts[2])) * 1000;

                            obj[property] = { ms: ms };

                        }

                        // NUMERO
                        else if (typeof value === "number") {
                            obj[property] = value;
                        }

                        // TEXTO
                        else {
                            obj[property] = value.toString().trim();
                        }

                    } catch (err) {
                        errorRows.push(index + 2);
                    }

                });

                aData.push(obj);

            });

            if (!aData.length) {
                sap.m.MessageBox.error("No hay datos válidos en el Excel");
                return;
            }

            var oModel = this.getView().getModel("mapfresa");

            // limpiar tabla
            oModel.setProperty("/naturaleza", []);
            oModel.refresh(true);

            // cargar datos
            oModel.setProperty("/naturaleza", aData);
            oModel.refresh(true);

            if (errorRows.length) {

                sap.m.MessageBox.warning(
                    "Algunas filas tienen errores: " + errorRows.join(", ")
                );

            } else {

                sap.m.MessageToast.show(
                    "Excel importado correctamente (" + aData.length + " filas)"
                );

            }

        } catch (err) {

            sap.m.MessageBox.error("Error leyendo el Excel");

            console.error(err);

        }

    }.bind(this);

    reader.readAsArrayBuffer(oFile);
}
