onNumberChange: function (oEvent) {

    var oInput = oEvent.getSource();
    var oModel = this._oDialog.getModel("modeloDatos");

    var sPath = oInput.getBinding("value").getPath();
    var sValue = oEvent.getParameter("value");

    var sClean = sValue.replace(/[^0-9]/g, "");

    oInput.setValue(sClean);
    oModel.setProperty("/" + sPath, sClean);

    var iValue = Number(sClean);

    // 🔥 prendo regole dalla VIEW
    var iMin = Number(oInput.data("min"));
    var iMax = oInput.data("max");

    // 👉 se max non c'è → anno corrente
    if (!iMax) {
        iMax = new Date().getFullYear();
    } else {
        iMax = Number(iMax);
    }

    var bError =
        !sClean ||
        isNaN(iValue) ||
        (iMin && iValue < iMin) ||
        (iMax && iValue > iMax);

    oModel.setProperty("/" + sPath + "State", bError ? "Error" : "None");
}
