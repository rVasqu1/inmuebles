 onOnlyNumber: function (oEvent) {

        var oModel= this._oDialog.getModel("modeloDatos");
        var oData = oModel.getData();
        var sValue = oEvent.getParameter("value");
        var sClean = sValue.replace(/[^0-9]/g,"");

        if (!oData.mese || oData.mese < 1 || oData.mese >12) {
            oModel.setProperty ("/meseState", "Error");
            bValid= false;
        } else {
            oModel.setProperty("/meseState", "Success");
            bValid= false;
        }

        sClean = sClean.slice(0,4);
        oEvent.getSource().setValue(sClean);
    }
