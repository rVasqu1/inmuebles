  dowloadExcelCeco: function () {
                var oTable = this.byId("tableCeco");
                // Se obtiene el binding de sus filas
                var oBinding = oTable.getBinding("rows");
                // Se obtiene los contexto de cada fila
                var aContexts = oBinding.getContexts();
                //Se comprueba si tamaño del array de contextos es distinto a 0
                if (!aContexts.length) {
                    sap.m.MessageToast.show("No hay datos para exportar");
                    return;
                }
                //Recorriendo los contextos para obtener los datos
                var aData = aContexts.map(function (oContext) {
                    return oContext.getObject();
                });
                // Array de columnas
                var aColumns = [];
                // Recorremos las columnas
                oTable.getColumns().forEach(function (oColumn) {
                    //Se obtiene el label
                    var oLabel = oColumn.getLabel();
                    // En caso que exista el label, se trae su texto, si no vacío
                    var sLabel = oLabel ? oLabel.getText() : "";
                    //Como se agrega el valor por sort o filter, identificamos la propiedad
                    var sProperty = oColumn.getSortProperty() || oColumn.getFilterProperty() || "";
                    //Se hace un if para setear 
                    if (!sProperty) {
                        return;
                    }
                    //if para determinar si el tipo es Date o String
                    if (sProperty === "DateHigh" || sProperty === "DateLow" || sProperty === "ExecutionDate") {
                        aColumns.push({
                            label: sLabel,
                            property: sProperty,
                            type: sap.ui.export.EdmType.Date
                        });
                    } else {
                        aColumns.push({
                            label: sLabel,
                            property: sProperty,
                            type: sap.ui.export.EdmType.String
                        });
                    }
                });
                //Recorriendo los contextos para obtener los datos
                var aFormattedData = aData.map(function (oItem) {
                    // Array de columna
                    var oRow = {};
                    // Recorremos las columnas
                    aColumns.forEach(function (oCol) {
                        //Creando variable para llegar a ExecutionHourdesde array
                        var vValue = oItem[oCol.property];
                        //Buscar la columna que apunta a ExecutionHour
                        if (oCol.property === "ExecutionHour") {
                            //Creando condición para comprobar si hay un objecto o si es indefinido
                            if (vValue && typeof vValue === "object" && vValue.ms !== undefined) {

                                var totalSeconds = Math.floor(vValue.ms / 1000);
                                //caluclo para obtener horas, minutos y segundos
                                var h = Math.floor(totalSeconds / 3600);
                                var m = Math.floor((totalSeconds % 3600) / 60);
                                var s = totalSeconds % 60;

                                vValue =
                                    h.toString().padStart(2, "0") + ":" +
                                    m.toString().padStart(2, "0") + ":" +
                                    s.toString().padStart(2, "0");
                            }
                        }
                        // si es vacio me devuelve el campo vacio 
                        if (vValue === null || vValue === undefined) {
                            vValue = "";
                        }

                        oRow[oCol.property] = vValue;
                    });

                    return oRow;

                });
                // Se crea la configuracion del excel
                var oSettings = {
                    workbook: {
                        columns: aColumns
                    },
                    dataSource: aFormattedData,
                    fileName: this.oResourceBundle.getText("nombreExcel") + ".xlsx",
                    worker: false
                };
                //Se genera un excel
                var oSheet = new sap.ui.export.Spreadsheet(oSettings);
                //Se descarga el excel
                oSheet.build().finally(function () {
                    oSheet.destroy();
                });

            },
