oFileUpload: function (oEvent) {

    var oFile = oEvent.getParameter("files")[0];
    if (!oFile) return;

    var reader = new FileReader();

    reader.onload = function (e) {

        var data = new Uint8Array(e.target.result);
        var workbook = XLSX.read(data, { type: "array" });
        var sheet = workbook.Sheets[workbook.SheetNames[0]];

        // leer excel
        var rows = XLSX.utils.sheet_to_json(sheet);

        if (!rows.length) {
            sap.m.MessageToast.show("Excel vacío");
            return;
        }

        var oTable = this.byId("tableNaturaleza");

        // obtener propiedades reales de la tabla
        var aProperties = oTable.getColumns()
            .map(function (oCol) {
                return oCol.getSortProperty() || oCol.getFilterProperty();
            })
            .filter(Boolean);

        var aData = rows.map(function (row, index) {

            var obj = {
                _numerico: index + 1
            };

            aProperties.forEach(function (prop) {

                var value = row[prop];

                if (value === undefined) return;

                // fecha
                if (value instanceof Date) {
                    obj[prop] = value;
                }

                // hora HH:mm:ss
                else if (typeof value === "string" && value.match(/^\d{2}:\d{2}:\d{2}$/)) {

                    var parts = value.split(":");

                    var ms =
                        (parseInt(parts[0]) * 3600 +
                        parseInt(parts[1]) * 60 +
                        parseInt(parts[2])) * 1000;

                    obj[prop] = { ms: ms };
                }

                else {
                    obj[prop] = value;
                }

            });

            return obj;

        });

        var oModel = this.getView().getModel("mapfresa");

        // reemplazar datos
        oModel.setProperty("/naturaleza", []);
        oModel.refresh(true);

        oModel.setProperty("/naturaleza", aData);
        oModel.refresh(true);

        sap.m.MessageToast.show("Excel cargado correctamente");

    }.bind(this);

    reader.readAsArrayBuffer(oFile);
}
