onDownloadExcel: function () {
    var oTable = this.byId("tableNaturaleza");
    var oBinding = oTable.getBinding("rows");

    var aData = oBinding.getContexts().map(function(oContext) {
        return oContext.getObject();
    });

    if (!aData || aData.length === 0) {
        sap.m.MessageToast.show("No hay datos para exportar");
        return;
    }

    // 1. Crear columnas dinámicas
    var aColumns = oTable.getColumns().map(function(oColumn) {
        var sLabel = oColumn.getLabel().getText();
        var oTemplate = oColumn.getTemplate();
        var sProperty = "";

        if (oTemplate.isA("sap.ui.comp.smartfield.SmartField")) {
            var oInner = oTemplate._getContent();
            if (oInner) {
                var oBindInfo;
                if (oInner.isA("sap.m.DatePicker") || oInner.isA("sap.m.DateTimePicker")) {
                    oBindInfo = oInner.getBindingInfo("dateValue");
                } else if (oInner.isA("sap.m.Input")) {
                    oBindInfo = oInner.getBindingInfo("value");
                } else if (oInner.isA("sap.m.Select")) {
                    oBindInfo = oInner.getBindingInfo("selectedKey");
                } else if (oInner.isA("sap.m.CheckBox")) {
                    oBindInfo = oInner.getBindingInfo("selected");
                } else {
                    oBindInfo = oInner.getBindingInfo("text");
                }
                sProperty = oBindInfo ? (oBindInfo.parts ? oBindInfo.parts[0].path : oBindInfo.path) : "";
            }
        } else {
            var oBindInfo = oTemplate.getBindingInfo("text") || oTemplate.getBindingInfo("value") || oTemplate.getBindingInfo("selectedKey");
            sProperty = oBindInfo ? (oBindInfo.parts ? oBindInfo.parts[0].path : oBindInfo.path) : "";
        }

        return {
            label: sLabel,
            property: sProperty,
            type: sap.ui.export.EdmType.String
        };
    });

    // 2. Formatear datos
    var aFormattedData = aData.map(function(oItem) {
        var oRow = {};
        aColumns.forEach(function(oCol) {
            var vValue = oItem[oCol.property];

            if (vValue instanceof Date) {
                // Detectar si tiene hora
                if (vValue.getHours() || vValue.getMinutes() || vValue.getSeconds()) {
                    // Fecha y hora: DD/MM/YYYY HH:mm:ss
                    vValue = vValue.toLocaleDateString() + " " +
                             vValue.getHours().toString().padStart(2,"0") + ":" +
                             vValue.getMinutes().toString().padStart(2,"0") + ":" +
                             vValue.getSeconds().toString().padStart(2,"0");
                } else {
                    // Solo fecha: DD/MM/YYYY
                    vValue = vValue.toLocaleDateString();
                }
            }

            oRow[oCol.property] = vValue != null ? vValue : "";
        });
        return oRow;
    });

    // 3. Exportar Excel
    var oSettings = {
        workbook: { columns: aColumns },
        dataSource: aFormattedData,
        fileName: "Export_Tabla.xlsx",
        worker: false
    };

    var oSheet = new sap.ui.export.Spreadsheet(oSettings);
    oSheet.build().finally(function() {
        oSheet.destroy();
    });
}
