onDownloadExcel: function () {
    var oTable = this.byId("tableNaturaleza");
    var oBinding = oTable.getBinding("rows"); // binding de la tabla
    
    // 1. Obtener los datos actuales (respetando filtros y ordenamientos)
    var aData = oBinding.getContexts().map(function(oContext) {
        return oContext.getObject();
    });

    if (!aData || aData.length === 0) {
        sap.m.MessageToast.show("No hay datos para exportar");
        return;
    }

    // 2. Obtener las columnas dinámicamente de la tabla
    var aColumns = oTable.getColumns().map(function(oColumn) {
        var sLabel = oColumn.getLabel().getText();
        var oTemplate = oColumn.getTemplate();

        // Obtener el path del binding de la celda (usualmente 'text' o 'title')
        var oBindingInfo = oTemplate.getBindingInfo("text") || oTemplate.getBindingInfo("title");
        var sProperty = "";
        if (oBindingInfo) {
            // Si hay varios bindings (parts), tomar el primero
            sProperty = oBindingInfo.parts ? oBindingInfo.parts[0].path : oBindingInfo.path;
        }

        return {
            label: sLabel,
            property: sProperty,
            type: sap.ui.export.EdmType.String
        };
    });

    // 3. Configuración de Excel
    var oSettings = {
        workbook: { columns: aColumns },
        dataSource: aData,
        fileName: "Export_Tabla.xlsx",
        worker: false
    };

    // 4. Generar y descargar el Excel
    var oSheet = new sap.ui.export.Spreadsheet(oSettings);
    oSheet.build().finally(function() {
        oSheet.destroy();
    });
}
