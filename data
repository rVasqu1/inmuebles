dowloadExceltipoCeco: function () {
    var oTable = this.byId("tableTipoCeco");
    var oBinding = oTable.getBinding("rows");
    var aContexts = oBinding.getContexts();

    if (!aContexts.length) {
        sap.m.MessageToast.show("No hay datos para exportar");
        return;
    }

    var aData = aContexts.map(function (oContext) {
        return oContext.getObject();
    });

    var aColumns = [];

    oTable.getColumns().forEach(function (oColumn) {
        // Salta colonne invisibili o senza label
        if (!oColumn.getVisible()) return;

        var oLabel = oColumn.getLabel();
        var sLabel = oLabel ? oLabel.getText() : "";
        if (!sLabel) return; // salta la colonna numerica senza label

        // ✅ Legge la property dal binding del template
        var oTemplate = oColumn.getTemplate();
        var sProperty = null;

        if (oTemplate) {
            var oBindingInfo = oTemplate.getBindingInfo("value") || oTemplate.getBindingInfo("text");
            if (oBindingInfo && oBindingInfo.parts && oBindingInfo.parts.length > 0) {
                // Rimuove il prefisso del model es. "mapfresa>" -> "Orden"
                sProperty = oBindingInfo.parts[0].path;
            }
        }

        if (!sProperty) return; // salta se non trova property

        aColumns.push({
            label: sLabel,
            property: sProperty,
            type: sap.ui.export.EdmType.String
        });
    });

    if (!aColumns.length) {
        sap.m.MessageToast.show("No hay columnas para exportar");
        return;
    }

    var oSettings = {
        workbook: { columns: aColumns },
        dataSource: aData,
        fileName: this.oResourceBundle.getText("nombreExcel") + ".xlsx",
        worker: false
    };

    var oSheet = new sap.ui.export.Spreadsheet(oSettings);
    oSheet.build().finally(function () {
        oSheet.destroy();
    });
},
